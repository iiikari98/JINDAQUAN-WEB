# NetEase enterprise mailbox SMTP settings.
# Copy this file to .env.local and put the real SMTP authorization code there.
SMTP_HOST=smtp.qiye.163.com
SMTP_PORT=994
SMTP_USER=gsq@jindaquan.com
SMTP_PASS=replace_with_netease_smtp_authorization_code
INQUIRY_FROM=gsq@jindaquan.com
INQUIRY_TO=gsq@jindaquan.com

# Optional. Use this when local DNS/proxy maps SMTP hosts to 198.18.x.x fake IPs.
# SMTP_PROXY=http://127.0.0.1:7897
